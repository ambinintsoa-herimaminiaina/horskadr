---
---
<header id="navbar">
  <nav class="max-w-7xl mx-auto px-6 lg:px-10 h-[70px] flex items-center justify-between">

    <!-- Logo -->
    <a href="#accueil" class="flex items-center gap-1 shrink-0">
      <span class="font-display text-2xl tracking-widest text-white leading-none">
        H<span class="inline-flex items-center justify-center w-[18px] h-[18px] bg-hk-red rounded-full mx-[2px] relative top-[-1px]">
          <span class="block w-[5px] h-[5px] bg-hk-black rounded-full"></span>
        </span>RS KADR
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-8">
      <li><a class="nav-link" href="#accueil">Accueil</a></li>
      <li><a class="nav-link" href="#a-propos">À propos</a></li>
      <li><a class="nav-link" href="#nos-projets">Nos projets</a></li>
      <li><a class="nav-link" href="#engagements">Engagements</a></li>
      <li><a class="nav-link" href="#contact">Contact</a></li>
    </ul>

    <!-- Right -->
    <div class="flex items-center gap-4">
      <button id="lang-btn" class="text-[11px] font-semibold tracking-widest uppercase text-hk-muted hover:text-hk-red transition-colors">
        MG
      </button>
      <a href="#contact" class="btn-primary hidden lg:inline-flex py-2.5 px-5 text-[11px]">
        Contactez-nous
      </a>
      <!-- Hamburger -->
      <button id="burger" class="lg:hidden flex flex-col gap-[5px]" aria-label="Menu">
        <span class="w-6 h-[1.5px] bg-white block transition-all"></span>
        <span class="w-4 h-[1.5px] bg-hk-red block transition-all"></span>
        <span class="w-6 h-[1.5px] bg-white block transition-all"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-hk-black border-t border-hk-border px-6 py-8">
    <ul class="flex flex-col gap-6">
      <li><a class="font-display text-3xl tracking-wider text-white hover:text-hk-red transition-colors" href="#accueil">Accueil</a></li>
      <li><a class="font-display text-3xl tracking-wider text-white hover:text-hk-red transition-colors" href="#a-propos">À propos</a></li>
      <li><a class="font-display text-3xl tracking-wider text-white hover:text-hk-red transition-colors" href="#nos-projets">Nos projets</a></li>
      <li><a class="font-display text-3xl tracking-wider text-white hover:text-hk-red transition-colors" href="#engagements">Engagements</a></li>
      <li><a class="font-display text-3xl tracking-wider text-white hover:text-hk-red transition-colors" href="#contact">Contact</a></li>
    </ul>
  </div>
</header>

<script>
  // Burger toggle
  const burger = document.getElementById('burger')!;
  const menu   = document.getElementById('mobile-menu')!;
  const lines  = burger.querySelectorAll<HTMLSpanElement>('span');

  burger.addEventListener('click', () => {
    const open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', open);
    lines[0].style.transform = open ? '' : 'translateY(6.5px) rotate(45deg)';
    lines[1].style.opacity   = open ? '' : '0';
    lines[2].style.transform = open ? '' : 'translateY(-6.5px) rotate(-45deg)';
  });

  // Close mobile menu on link click
  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      lines[0].style.transform = '';
      lines[1].style.opacity   = '';
      lines[2].style.transform = '';
    });
  });
</script>
