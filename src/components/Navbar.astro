---
---
<header id="navbar">
  <nav class="max-w-7xl mx-auto px-6 lg:px-10 h-[70px] flex items-center justify-between">

    <!-- Logo -->
    <a href="#accueil" class="flex items-center shrink-0">
      <span class="font-display text-2xl tracking-widest leading-none" style="color:#F0F5F0">
        H<span class="inline-flex items-center justify-center mx-[2px] relative top-[-1px]"
              style="width:18px;height:18px;background:#AAFF57;border-radius:50%">
          <span style="display:block;width:5px;height:5px;background:#060D0A;border-radius:50%"></span>
        </span>RS KADR
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-8">
      <li><a class="nav-link" href="#accueil">Accueil</a></li>
      <li><a class="nav-link" href="#a-propos">À propos</a></li>
      <li><a class="nav-link" href="#nos-projets">Nos projets</a></li>
      <li><a class="nav-link" href="#engagements">Engagements</a></li>
      <li><a class="nav-link" href="#contact">Contact</a></li>
    </ul>

    <!-- Right -->
    <div class="flex items-center gap-4">
      <a href="#contact" class="btn-lime hidden lg:inline-flex py-2.5 px-5 text-[11px]">
        Contactez-nous
      </a>
      <!-- Hamburger -->
      <button id="burger" class="lg:hidden flex flex-col gap-[5px]" aria-label="Menu">
        <span class="w-6 h-[1.5px] block transition-all" style="background:#F0F5F0"></span>
        <span class="w-4 h-[1.5px] block transition-all" style="background:#AAFF57"></span>
        <span class="w-6 h-[1.5px] block transition-all" style="background:#F0F5F0"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden px-6 py-8" style="background:#060D0A;border-top:1px solid rgba(170,255,87,0.1)">
    <ul class="flex flex-col gap-6">
      <li><a class="font-display text-3xl tracking-wider transition-colors" style="color:#F0F5F0" href="#accueil">Accueil</a></li>
      <li><a class="font-display text-3xl tracking-wider transition-colors" style="color:#F0F5F0" href="#a-propos">À propos</a></li>
      <li><a class="font-display text-3xl tracking-wider transition-colors" style="color:#F0F5F0" href="#nos-projets">Nos projets</a></li>
      <li><a class="font-display text-3xl tracking-wider transition-colors" style="color:#F0F5F0" href="#engagements">Engagements</a></li>
      <li><a class="font-display text-3xl tracking-wider transition-colors" style="color:#F0F5F0" href="#contact">Contact</a></li>
    </ul>
  </div>
</header>

<script>
  const burger = document.getElementById('burger')!;
  const menu   = document.getElementById('mobile-menu')!;
  const lines  = burger.querySelectorAll<HTMLSpanElement>('span');

  burger.addEventListener('click', () => {
    const open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', open);
    lines[0].style.transform = open ? '' : 'translateY(6.5px) rotate(45deg)';
    lines[1].style.opacity   = open ? '' : '0';
    lines[2].style.transform = open ? '' : 'translateY(-6.5px) rotate(-45deg)';
  });

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      lines[0].style.transform = '';
      lines[1].style.opacity   = '';
      lines[2].style.transform = '';
    });
  });
</script>
