<canvas id="grain" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById('grain') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let animFrame: number;
  let lastTime = 0;
  const FPS = 12; // throttle — grain doesn't need 60fps
  const INTERVAL = 1000 / FPS;

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function drawGrain(ts: number) {
    animFrame = requestAnimationFrame(drawGrain);
    if (ts - lastTime < INTERVAL) return;
    lastTime = ts;

    const w = canvas.width;
    const h = canvas.height;
    const imageData = ctx.createImageData(w, h);
    const data = imageData.data;
    for (let i = 0; i < data.length; i += 4) {
      const v = (Math.random() * 255) | 0;
      data[i] = data[i+1] = data[i+2] = v;
      data[i+3] = 255;
    }
    ctx.putImageData(imageData, 0, 0);
  }

  function start() { animFrame = requestAnimationFrame(drawGrain); }
  function stop()  { cancelAnimationFrame(animFrame); }

  resize();
  start();

  window.addEventListener('resize', resize, { passive: true });
  document.addEventListener('visibilitychange', () =>
    document.hidden ? stop() : start()
  );
</script>
