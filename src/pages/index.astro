---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/index';

const lang = 'fr';
const t = translations[lang];
const h = t.hero;
const at = t.about_teaser;
const pt = t.projects_teaser;
const ct = t.cta_band;
const projects = t.projects.verticals;
---

<Layout title="HORS KADR" currentPage="/" lang={lang}>

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-screen flex flex-col justify-center px-6 lg:px-12 max-w-7xl mx-auto">

    <!-- Background cross mark -->
    <div class="absolute right-12 top-1/3 w-px h-40 bg-white/5 hidden lg:block"></div>
    <div class="absolute right-12 top-1/3 mt-20 w-40 h-px bg-white/5 -translate-x-20 hidden lg:block"></div>

    <div class="pt-24">
      <!-- Label -->
      <p id="hero-label" class="text-xs font-bold uppercase tracking-[0.3em] text-hk-red mb-8 opacity-0">
        Madagascar · {new Date().getFullYear()}
      </p>

      <!-- Main title -->
      <h1 id="hero-title" class="font-display font-black text-[clamp(4rem,12vw,10rem)] leading-[0.9] uppercase tracking-tight mb-8 opacity-0">
        {h.tagline}
      </h1>

      <!-- Subtitle -->
      <p id="hero-sub" class="text-hk-muted text-lg lg:text-xl max-w-lg leading-relaxed mb-12 opacity-0">
        {h.description}
      </p>

      <!-- CTAs -->
      <div id="hero-ctas" class="flex flex-wrap gap-4 opacity-0">
        <a href="/nos-projets" class="btn-primary">{h.cta_primary} ↗</a>
        <a href="/a-propos" class="btn-outline">{h.cta_secondary}</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div id="scroll-indicator" class="absolute bottom-10 left-6 lg:left-12 flex items-center gap-3 opacity-0">
      <div class="w-px h-12 bg-hk-red animate-pulse"></div>
      <span class="text-xs uppercase tracking-[0.3em] text-hk-muted">{h.scroll}</span>
    </div>
  </section>

  <!-- ═══ TICKER ═══ -->
  <div class="border-y border-white/5 py-5 overflow-hidden my-8">
    <div class="marquee-track">
      {[...t.ticker, ...t.ticker].map((item) => (
        <span class="font-display font-bold text-sm uppercase tracking-[0.25em] text-hk-muted whitespace-nowrap">
          {item} <span class="text-hk-red mx-4">✦</span>
        </span>
      ))}
    </div>
  </div>

  <!-- ═══ ABOUT TEASER ═══ -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text -->
      <div>
        <p data-animate class="text-xs font-bold uppercase tracking-[0.3em] text-hk-red mb-6">{at.label}</p>
        <h2 data-animate class="font-display font-black text-4xl lg:text-5xl xl:text-6xl uppercase leading-[1] mb-8 whitespace-pre-line">
          {at.title}
        </h2>
        <p data-animate class="text-hk-muted leading-relaxed max-w-md mb-10">
          {at.body}
        </p>
        <a data-animate href="/a-propos" class="btn-outline">{at.cta} →</a>
      </div>

      <!-- Visual -->
      <div data-animate class="relative aspect-square max-w-md mx-auto lg:mx-0">
        <div class="absolute inset-0 border border-white/8"></div>
        <div class="absolute inset-4 border border-white/5"></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <span class="font-display font-black text-[clamp(5rem,15vw,9rem)] text-white/5 uppercase select-none leading-none">HK</span>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-24 h-24 bg-hk-red rounded-full flex items-center justify-center">
              <span class="font-display font-black text-4xl text-hk-black">●</span>
            </div>
          </div>
        </div>
        <!-- Corner marks -->
        <div class="absolute top-0 left-0 w-4 h-4 border-t border-l border-hk-red"></div>
        <div class="absolute top-0 right-0 w-4 h-4 border-t border-r border-hk-red"></div>
        <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l border-hk-red"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-hk-red"></div>
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS TEASER ═══ -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 pb-24 lg:pb-32">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-12">
      <div>
        <p data-animate class="text-xs font-bold uppercase tracking-[0.3em] text-hk-red mb-4">{pt.label}</p>
        <h2 data-animate class="font-display font-black text-4xl lg:text-5xl uppercase leading-[1] whitespace-pre-line">
          {pt.title}
        </h2>
      </div>
      <a data-animate href="/nos-projets" class="btn-outline shrink-0">{pt.cta} ↗</a>
    </div>

    <div data-animate-stagger class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {projects.map((p) => (
        <div class="vertical-card">
          <div class="mb-6">
            <span class={`badge ${p.status === 'active' ? 'badge-active' : 'badge-soon'}`}>
              {p.status === 'active'
                ? t.projects.status_active
                : p.status === 'soon'
                ? t.projects.status_soon
                : t.projects.status_2027}
            </span>
          </div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-hk-muted mb-2">{p.tag}</p>
          <h3 class="font-display font-bold text-lg uppercase leading-tight mb-3">{p.name}</h3>
          <p class="text-hk-muted text-sm leading-relaxed">{p.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ CTA BAND ═══ -->
  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-24 lg:py-32 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-12">
      <h2 data-animate class="font-display font-black text-4xl lg:text-6xl xl:text-7xl uppercase leading-[1] whitespace-pre-line">
        {ct.title}
      </h2>
      <a data-animate href="/contact" class="btn-primary text-base py-4 px-8 shrink-0">
        {ct.cta} ↗
      </a>
    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';

  // Hero entrance animation
  const tl = gsap.timeline({ delay: 0.5 });

  tl.to('#hero-label',     { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
    .to('#hero-title',     { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3')
    .to('#hero-sub',       { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.5')
    .to('#hero-ctas',      { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.4')
    .to('#scroll-indicator', { opacity: 1, duration: 0.6, ease: 'power3.out' }, '-=0.3');
</script>
