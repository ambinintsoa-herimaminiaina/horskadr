---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/index';

const lang = 'fr';
const t = translations[lang].about;
---

<Layout title="À propos" currentPage="/a-propos" lang={lang}>

  <!-- Hero -->
  <section class="page-hero max-w-7xl mx-auto px-6 lg:px-12">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-hk-red mb-6 opacity-0" id="page-label">
      {t.hero_label}
    </p>
    <h1 class="font-display font-black text-[clamp(3.5rem,10vw,8rem)] uppercase leading-[0.9] whitespace-pre-line opacity-0" id="page-title">
      {t.hero_title}
    </h1>
  </section>

  <!-- Vision -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <div class="section-line"></div>
        <p data-animate class="text-xs font-bold uppercase tracking-[0.3em] text-hk-muted">{t.vision_label}</p>
      </div>
      <div class="lg:col-span-8">
        <h2 data-animate class="font-display font-black text-3xl lg:text-4xl uppercase leading-tight mb-6">
          {t.vision_title}
        </h2>
        <p data-animate class="text-hk-muted text-lg leading-relaxed max-w-2xl">
          {t.vision_body}
        </p>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="border-t border-white/5"></div>
  </div>

  <!-- Philosophy -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <div class="section-line"></div>
        <p data-animate class="text-xs font-bold uppercase tracking-[0.3em] text-hk-muted">{t.philosophy_label}</p>
      </div>
      <div class="lg:col-span-8">
        <h2 data-animate class="font-display font-black text-3xl lg:text-4xl uppercase leading-tight mb-6">
          {t.philosophy_title}
        </h2>
        <p data-animate class="text-hk-muted text-lg leading-relaxed max-w-2xl">
          {t.philosophy_body}
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 py-24 border-t border-white/5">
    <div class="mb-12">
      <div class="section-line"></div>
      <p data-animate class="text-xs font-bold uppercase tracking-[0.3em] text-hk-muted">{t.values_label}</p>
    </div>
    <div data-animate-stagger class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {t.values.map((v) => (
        <div class="vertical-card">
          <h3 class="font-display font-bold text-xl uppercase mb-4">{v.title}</h3>
          <p class="text-hk-muted leading-relaxed">{v.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <h2 data-animate class="font-display font-black text-3xl lg:text-4xl uppercase">
        Nos projets concrets →
      </h2>
      <a data-animate href="/nos-projets" class="btn-primary shrink-0">Voir les verticales ↗</a>
    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';

  gsap.timeline({ delay: 0.4 })
    .to('#page-label', { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' })
    .to('#page-title', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3');
</script>
