---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/index';

const lang = 'fr';
const t = translations[lang].projects;
---

<Layout title="Nos projets" currentPage="/nos-projets" lang={lang}>

  <!-- Hero -->
  <section class="page-hero max-w-7xl mx-auto px-6 lg:px-12">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-hk-red mb-6 opacity-0" id="page-label">
      {t.hero_label}
    </p>
    <h1 class="font-display font-black text-[clamp(3.5rem,10vw,8rem)] uppercase leading-[0.9] mb-8 whitespace-pre-line opacity-0" id="page-title">
      {t.hero_title}
    </h1>
    <p class="text-hk-muted text-lg max-w-xl leading-relaxed opacity-0" id="page-body">
      {t.hero_body}
    </p>
  </section>

  <!-- Verticals list -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 py-20">
    <div class="flex flex-col gap-6">
      {t.verticals.map((v, i) => (
        <article
          data-animate
          data-delay={String(i * 0.08)}
          class="vertical-card group flex flex-col lg:flex-row lg:items-center justify-between gap-8 p-8 lg:p-10"
        >
          <!-- Left -->
          <div class="flex-1">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-[10px] font-bold uppercase tracking-widest text-hk-muted">{v.tag}</span>
              <span class={`badge ${
                v.status === 'active' ? 'badge-active' :
                'badge-soon'
              }`}>
                {v.status === 'active' ? t.status_active
                : v.status === 'soon'  ? t.status_soon
                : t.status_2027}
              </span>
            </div>
            <h2 class="font-display font-black text-2xl lg:text-3xl uppercase mb-4">
              {v.name}
            </h2>
            <p class="text-hk-muted leading-relaxed max-w-xl">
              {v.description}
            </p>
          </div>

          <!-- Index number -->
          <div class="shrink-0">
            <span class="font-display font-black text-7xl lg:text-8xl text-white/5 group-hover:text-hk-red/10 transition-colors select-none leading-none">
              {String(i + 1).padStart(2, '0')}
            </span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <h2 data-animate class="font-display font-black text-3xl lg:text-4xl uppercase">
        Un projet en tête ?
      </h2>
      <a data-animate href="/contact" class="btn-primary shrink-0">Parlons-en ↗</a>
    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';

  gsap.timeline({ delay: 0.4 })
    .to('#page-label', { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' })
    .to('#page-title', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3')
    .to('#page-body',  { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.4');
</script>
