---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/index';

const lang = 'fr';
const t = translations[lang].commitments;
---

<Layout title="Engagements" currentPage="/engagements" lang={lang}>

  <!-- Hero -->
  <section class="page-hero max-w-7xl mx-auto px-6 lg:px-12">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-hk-red mb-6 opacity-0" id="page-label">
      {t.hero_label}
    </p>
    <h1 class="font-display font-black text-[clamp(3.5rem,10vw,8rem)] uppercase leading-[0.9] whitespace-pre-line opacity-0" id="page-title">
      {t.hero_title}
    </h1>
  </section>

  <!-- Commitments list -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 py-20">
    <div class="flex flex-col divide-y divide-white/5">
      {t.items.map((item, i) => (
        <div
          data-animate
          data-delay={String(i * 0.07)}
          class="grid grid-cols-1 lg:grid-cols-12 gap-6 py-10 group"
        >
          <!-- Number -->
          <div class="lg:col-span-2 flex items-start">
            <span class="font-display font-black text-5xl lg:text-6xl text-white/8 group-hover:text-hk-red/20 transition-colors leading-none select-none">
              {item.number}
            </span>
          </div>

          <!-- Content -->
          <div class="lg:col-span-10">
            <h2 class="font-display font-bold text-2xl lg:text-3xl uppercase mb-4">
              {item.title}
            </h2>
            <p class="text-hk-muted leading-relaxed text-lg max-w-3xl">
              {item.body}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <h2 data-animate class="font-display font-black text-3xl lg:text-4xl uppercase">
        Ces valeurs résonnent<br/>avec vous ?
      </h2>
      <a data-animate href="/contact" class="btn-primary shrink-0">Travaillons ensemble ↗</a>
    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';

  gsap.timeline({ delay: 0.4 })
    .to('#page-label', { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' })
    .to('#page-title', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3');
</script>
