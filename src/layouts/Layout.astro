---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Grain from '../components/Grain.astro';

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
  lang?: 'fr' | 'mg';
}

const {
  title = 'HORS KADR',
  description = "L'Impact. Pionnier de l'innovation malgache.",
  currentPage = '/',
  lang = 'fr',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080808" />

    <!-- OG -->
    <meta property="og:title" content={`${title} — HORS KADR`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title === 'HORS KADR' ? title : `${title} — HORS KADR`}</title>
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-hk-black text-hk-white overflow-x-hidden">

    <!-- Grain -->
    <Grain />

    <!-- Cursor -->
    <Cursor />

    <!-- Page transition overlay -->
    <div id="page-overlay" class="fixed inset-0 bg-hk-black z-[9990] pointer-events-none" style="opacity:0;"></div>

    <!-- Navigation -->
    <Navbar lang={lang} currentPage={currentPage} />

    <!-- Content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <Footer lang={lang} />

    <!-- GSAP init -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Page reveal on load
      gsap.to('#page-overlay', {
        opacity: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: 0.1,
      });

      // Universal scroll-triggered animations
      gsap.utils.toArray<HTMLElement>('[data-animate]').forEach((el) => {
        const delay = parseFloat(el.dataset.delay || '0');
        gsap.fromTo(
          el,
          { opacity: 0, y: 55 },
          {
            opacity: 1,
            y: 0,
            duration: 0.9,
            delay,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 88%',
              once: true,
            },
          }
        );
      });

      // Staggered children (add data-animate-stagger to parent)
      gsap.utils.toArray<HTMLElement>('[data-animate-stagger]').forEach((parent) => {
        const children = parent.children;
        gsap.fromTo(
          children,
          { opacity: 0, y: 40 },
          {
            opacity: 1,
            y: 0,
            duration: 0.7,
            stagger: 0.12,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: parent,
              start: 'top 85%',
              once: true,
            },
          }
        );
      });

      // Page transition on link click
      document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((link) => {
        const href = link.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto')) return;

        link.addEventListener('click', (e) => {
          e.preventDefault();
          const overlay = document.getElementById('page-overlay')!;
          gsap.to(overlay, {
            opacity: 1,
            duration: 0.4,
            ease: 'power2.in',
            onComplete: () => { window.location.href = href; },
          });
        });
      });
    </script>

  </body>
</html>
